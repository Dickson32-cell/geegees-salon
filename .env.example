# Render PostgreSQL - use this for services (Prisma)
# IMPORTANT: Use INTERNAL Database URL when deploying to Render
# Get from: Render Dashboard -> Your Database -> Connections -> Internal Database URL
# Format: postgresql://user:pass@dpg-xxxxx/database (no region, no port)
DATABASE_URL="postgresql://username:password@dpg-xxxxx/your_database"

# Supabase Configuration - use this for bookings and media storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
