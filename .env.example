# Render PostgreSQL - use this for services (Prisma)
# Get this from Render Dashboard -> Your Database -> Connections -> External Database URL
DATABASE_URL="postgresql://username:password@your-db-host.oregon-postgres.render.com:5432/your_database"

# Supabase Configuration - use this for bookings and media storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
